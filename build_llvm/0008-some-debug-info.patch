From 827733f14ba6401d4d09bb1ffe6d7f3e50ee0622 Mon Sep 17 00:00:00 2001
From: Daniel Wappner <dwappner@dc.uba.ar>
Date: Mon, 6 Apr 2026 14:10:04 -0300
Subject: [PATCH 1/3] some debug info

---
 llvm/include/llvm/IR/IRBuilder.h                         | 4 ++++
 llvm/lib/IR/Type.cpp                                     | 4 ++++
 .../lib/Transforms/Instrumentation/SanitizerCoverage.cpp | 9 +++++++--
 3 files changed, 15 insertions(+), 2 deletions(-)

diff --git a/llvm/include/llvm/IR/IRBuilder.h b/llvm/include/llvm/IR/IRBuilder.h
index a1789759960d..c869b198825a 100644
--- a/llvm/include/llvm/IR/IRBuilder.h
+++ b/llvm/include/llvm/IR/IRBuilder.h
@@ -1743,6 +1743,10 @@ public:
                            const Twine &Name = "") {
     if (auto *V = Folder.FoldGEP(Ty, Ptr, IdxList, /*IsInBounds=*/true))
       return V;
+    errs() << "CreateInBoundsGEP: " << *Ty << ", " << *Ptr << ", IdxList = (size " << IdxList.size() << ")[";
+    for (Value *Idx : IdxList)
+      errs() << ", " << *Idx;
+    errs() << "]\n";
     return Insert(GetElementPtrInst::CreateInBounds(Ty, Ptr, IdxList), Name);
   }
 
diff --git a/llvm/lib/IR/Type.cpp b/llvm/lib/IR/Type.cpp
index 85b658c8a52f..268023e14a03 100644
--- a/llvm/lib/IR/Type.cpp
+++ b/llvm/lib/IR/Type.cpp
@@ -602,6 +602,7 @@ bool StructType::isLayoutIdentical(StructType *Other) const {
 
 Type *StructType::getTypeAtIndex(const Value *V) const {
   unsigned Idx = (unsigned)cast<Constant>(V)->getUniqueInteger().getZExtValue();
+
   assert(indexValid(Idx) && "Invalid structure index!");
   return getElementType(Idx);
 }
@@ -609,6 +610,7 @@ Type *StructType::getTypeAtIndex(const Value *V) const {
 bool StructType::indexValid(const Value *V) const {
   // Structure indexes require (vectors of) 32-bit integer constants.  In the
   // vector case all of the indices must be equal.
+  errs() << "StructType::indexValid: this = " << *this << ", V = " << *V;
   if (!V->getType()->isIntOrIntVectorTy(32))
     return false;
   if (isa<ScalableVectorType>(V->getType()))
@@ -617,6 +619,8 @@ bool StructType::indexValid(const Value *V) const {
   if (C && V->getType()->isVectorTy())
     C = C->getSplatValue();
   const ConstantInt *CU = dyn_cast_or_null<ConstantInt>(C);
+  errs() << ", CU = " << *CU << ", NumElements = " << getNumElements() << "\n";
+
   return CU && CU->getZExtValue() < getNumElements();
 }
 
diff --git a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
index 57558f191ee1..b5dd40a34ecf 100644
--- a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
+++ b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
@@ -1186,12 +1186,17 @@ static Value *gFPUOC_Struct(Value *V, Offsets offsetChain, Types typeChain,
       ConstantInt::get(Type::getInt32Ty(V->getContext()), 0),
       ConstantInt::get(Type::getInt32Ty(V->getContext()), offset)};
 
+  
   unsigned AddrSpace = V->getType()->getPointerAddressSpace();
-
+  
   PointerType *StructPtrTy = PointerType::get(structType, AddrSpace);
   Value *Cast = Builder.CreatePointerCast(V, StructPtrTy);
-  errs() << "GEP WITH STRUCT TYPE " << *structType << " AND Params " << offset
+  errs() << "GEP WITH STRUCT TYPE " << *structType << " AND offset " << offset
          << " ON VALUE " << *Cast << "\n";
+  errs() << "ARRAY PARAMS: (size " << arrayParam.size() << ")[";
+  for (Value *Param : arrayParam)
+    errs() << *Param << ", ";
+  errs() << "]\n";
   Value *GEP = Builder.CreateInBoundsGEP(structType, Cast, arrayParam);
 
   Offsets remaining_offsets =
-- 
