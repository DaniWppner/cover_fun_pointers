From 04f1d26fbd335365ad4c6725281258086a8a283a Mon Sep 17 00:00:00 2001
From: Daniel Wappner <dwappner@dc.uba.ar>
Date: Wed, 15 Apr 2026 11:49:21 -0300
Subject: [PATCH] output json to hardcoded path and safely accross processes

---
 llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
index 26cd186bb548..d1c7fe74a1b4 100644
--- a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
+++ b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
@@ -1065,7 +1065,9 @@ void ModuleSanitizerCoverage::InjectTraceForNakedFunctionPointerStores(
   DebugDump["InstrumentedStores"] = std::move(storeInstInfoArray);
   if (instrumented_count || FuncPointerArgTypes.size()) {
     json::Value FinalJson = std::move(DebugDump);
-    errs() << llvm::formatv("{0:2}", FinalJson) << ",\n";
+    std::error_code EC;
+    raw_fd_ostream JSONOut("/tmp/naked_pointers.json", EC, sys::fs::OF_Append);
+    JSONOut << llvm::formatv("{0:2}", FinalJson) << ",\n";
   }
 }
 
