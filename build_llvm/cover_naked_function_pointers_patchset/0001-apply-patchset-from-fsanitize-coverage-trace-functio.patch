+typedef std::vector<Type *> Types;
+typedef std::vector<int> Offsets;
+typedef std::vector<std::pair<Types, Offsets>> vectorTypesOffsets;
+typedef std::pair<bool, vectorTypesOffsets> retType;
+
+// Unused, for debugging purposes
+static void showTypeAndOffsetChain(Types typeChain, Offsets offsetChain) {
+  errs() << "{\n";
+  for (unsigned j = 0; j < typeChain.size(); j++) {
+    errs() << std::string('\t', j) << "Type: " << *typeChain[j]
+           << " Offset: " << offsetChain[j] << "\n";
+  }
+  errs() << "}\n";
+}
+
+// Unused, for debugging purposes
+static void ShowTypesOffsets(vectorTypesOffsets typesOffsets) {
+  errs() << "(size " << typesOffsets.size() << ") \n{\n";
+  for (unsigned i = 0; i < typesOffsets.size(); i++) {
+    showTypeAndOffsetChain(typesOffsets[i].first, typesOffsets[i].second);
+  }
+  errs() << "}\n";
+}
+
+// Unused, for debugging purposes
+template <typename T>
+static void ShowPointerVector(std::vector<T *> genericVector) {
+  errs() << "(size " << genericVector.size() << ") \n{\n";
+  for (unsigned i = 0; i < genericVector.size(); i++) {
+    errs() << *genericVector[i] << "\n";
+  }
+  errs() << "}\n";
+}
+
+// Unused, for debugging purposes
+template <typename T>
+static void ShowElementVector(std::vector<T> genericVector) {
+  errs() << "(size " << genericVector.size() << ") \n{\n";
+  for (unsigned i = 0; i < genericVector.size(); i++) {
+    errs() << genericVector[i] << "\n";
+  }
+  errs() << "}\n";
+}
