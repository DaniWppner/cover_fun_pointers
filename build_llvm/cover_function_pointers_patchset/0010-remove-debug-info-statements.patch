Subject: [PATCH 3/3] remove debug info statements

---
 llvm/include/llvm/IR/IRBuilder.h              |  4 --
 llvm/lib/IR/Type.cpp                          |  4 --
 .../Instrumentation/SanitizerCoverage.cpp     | 44 +++++--------------
 3 files changed, 12 insertions(+), 40 deletions(-)

diff --git a/llvm/include/llvm/IR/IRBuilder.h b/llvm/include/llvm/IR/IRBuilder.h
index c869b198825a..a1789759960d 100644
--- a/llvm/include/llvm/IR/IRBuilder.h
+++ b/llvm/include/llvm/IR/IRBuilder.h
@@ -1743,10 +1743,6 @@ public:
                            const Twine &Name = "") {
     if (auto *V = Folder.FoldGEP(Ty, Ptr, IdxList, /*IsInBounds=*/true))
       return V;
-    errs() << "CreateInBoundsGEP: " << *Ty << ", " << *Ptr << ", IdxList = (size " << IdxList.size() << ")[";
-    for (Value *Idx : IdxList)
-      errs() << ", " << *Idx;
-    errs() << "]\n";
     return Insert(GetElementPtrInst::CreateInBounds(Ty, Ptr, IdxList), Name);
   }
 
diff --git a/llvm/lib/IR/Type.cpp b/llvm/lib/IR/Type.cpp
index 268023e14a03..85b658c8a52f 100644
--- a/llvm/lib/IR/Type.cpp
+++ b/llvm/lib/IR/Type.cpp
@@ -602,7 +602,6 @@ bool StructType::isLayoutIdentical(StructType *Other) const {
 
 Type *StructType::getTypeAtIndex(const Value *V) const {
   unsigned Idx = (unsigned)cast<Constant>(V)->getUniqueInteger().getZExtValue();
-
   assert(indexValid(Idx) && "Invalid structure index!");
   return getElementType(Idx);
 }
@@ -610,7 +609,6 @@ Type *StructType::getTypeAtIndex(const Value *V) const {
 bool StructType::indexValid(const Value *V) const {
   // Structure indexes require (vectors of) 32-bit integer constants.  In the
   // vector case all of the indices must be equal.
-  errs() << "StructType::indexValid: this = " << *this << ", V = " << *V;
   if (!V->getType()->isIntOrIntVectorTy(32))
     return false;
   if (isa<ScalableVectorType>(V->getType()))
@@ -619,8 +617,6 @@ bool StructType::indexValid(const Value *V) const {
   if (C && V->getType()->isVectorTy())
     C = C->getSplatValue();
   const ConstantInt *CU = dyn_cast_or_null<ConstantInt>(C);
-  errs() << ", CU = " << *CU << ", NumElements = " << getNumElements() << "\n";
-
   return CU && CU->getZExtValue() < getNumElements();
 }
 
