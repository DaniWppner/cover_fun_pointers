From ed36082298992a0af5c7fb36ea2ae4f7a7c1d497 Mon Sep 17 00:00:00 2001
From: Daniel Wappner <dwappner@dc.uba.ar>
Date: Mon, 6 Apr 2026 15:45:08 -0300
Subject: [PATCH] fix: register naked function pointers, and pass the actual
 function pointer to the callback instead of a double pointer

---
 .../Instrumentation/SanitizerCoverage.cpp     | 25 ++++++++++++-------
 1 file changed, 16 insertions(+), 9 deletions(-)

diff --git a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
index f7552f8c2cf5..8aae36a262fa 100644
--- a/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
+++ b/llvm/lib/Transforms/Instrumentation/SanitizerCoverage.cpp
@@ -1010,7 +1010,6 @@ static void ShowElementVector(std::vector<T> genericVector) {
   errs() << "}\n";
 }
 
-
 static retType HandleTypeRecursive(Type *Ty);
 static retType RecursivelyHandlePointerType(PointerType *Ty) {
   Type *OrigType = Ty->getPointerElementType();
@@ -1028,7 +1027,8 @@ static retType RecursivelyHandleStructType(StructType *OriginalStruct) {
     vectorTypesOffsets this_types_offsets = res_Pos.second;
     if (any) {
       if (this_types_offsets.size() == 0) {
-        this_types_offsets.push_back(std::make_pair(Types{}, Offsets{}));
+        assert(false && "If a contained type can be stripped to a function pointer the offset list should not be empty anymore");
+        // this_types_offsets.push_back(std::make_pair(Types{}, Offsets{}));
       }
       for (unsigned j = 0; j < this_types_offsets.size(); j++) {
         Types this_types_j = this_types_offsets[j].first;
@@ -1053,13 +1053,12 @@ pointer.
 */
 static retType HandleTypeRecursive(Type *Ty) {
   if (!(Ty->isPointerTy() || Ty->isStructTy())) {
-    bool result;
     if (Ty->isFunctionTy()) {
-      result = true;
+      return std::make_pair(
+          true, vectorTypesOffsets{std::make_pair(Types{Ty}, Offsets{0})});
     } else {
-      result = false;
+      return std::make_pair(false, vectorTypesOffsets{});
     }
-    return std::make_pair(result, vectorTypesOffsets{});
   }
   if (Ty->isPointerTy())
     return RecursivelyHandlePointerType(dyn_cast<PointerType>(Ty));
@@ -1192,8 +1191,15 @@ static Value *getFunctionPointerUsingOffsetChain(Value *V, Offsets offsetChain,
                                                  Types typeChain,
                                                  IRBuilder<> &Builder) {
 
-  if (offsetChain.size() == 0) {
-    return V;
+  if (offsetChain.size() == 1) {
+    // We've recursively accessed structs and got to a pointer to the function
+    // pointer. We just need to load it now.
+
+    Type *FType = typeChain[0];
+    // Address space hardcoded to 0 here because that's where function pointers usually live.
+    Type *FPointerType = PointerType::get(FType, 0);
+    Value *FPointer = Builder.CreateLoad(FPointerType, V);
+    return FPointer;
   } else {
     return gFPUOC_Struct(V, offsetChain, typeChain, Builder);
   }
@@ -1206,7 +1212,6 @@ static Value *getFunctionPointerUsingOffsetChain(Value *V, Offsets offsetChain,
 void ModuleSanitizerCoverage::InjectTraceForFunctionPointerStores(
     Function &, ArrayRef<StoreInst *> Stores) {
 
-
   for (StoreInst *SI : Stores) {
     IRBuilder<> IRB(SI);
     Value *StorePtr = SI->getPointerOperand();
@@ -1230,6 +1235,8 @@ void ModuleSanitizerCoverage::InjectTraceForFunctionPointerStores(
         Value *FunctionPtr = getFunctionPointerUsingOffsetChain(
             StoredValue, offsetChain, typeChain, IRB);
 
+        assert(FunctionPtr->getType()->isPointerTy() && "The value retrieved from the offset chain is not a pointer");
+        assert(FunctionPtr->getType()->getPointerElementType()->isFunctionTy() && "The pointer retrieved from the offset chain doesn't point to a function");
         // It is unclear to me if it would be necessary to cast the
         // FunctionPtr to IntptrTy as InjectCoverageForIndirectCalls does.
         IRB.CreateCall(SanCovStoreFPointerFunction, {StorePtr, FunctionPtr});
-- 
