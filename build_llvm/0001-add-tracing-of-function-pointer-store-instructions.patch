     Function &F, DomTreeCallback DTCallback, PostDomTreeCallback PDTCallback) {
   if (F.empty())
@@ -674,7 +709,8 @@ void ModuleSanitizerCoverage::instrumentFunction(
   if (F.hasFnAttribute(Attribute::NoSanitizeCoverage))
