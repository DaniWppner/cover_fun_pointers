+// On every store to a function pointer variable call we call a run-time
+// function __sanitizer_cov_store_fun_pointer* with two parameters:
+//   - address of te variable,
+//   - stored function pointer
+void ModuleSanitizerCoverage::InjectTraceForFunctionPointerStores(
+    Function &, ArrayRef<StoreInst *> Stores) {
+
+  for (StoreInst *SI : Stores) {
+      InstrumentationIRBuilder IRB(SI);
+      Value *StorePtr = SI->getPointerOperand();
+      Value *FunctionPtr = SI->getValueOperand();
+
+      // It is unclear to me if it would be necessary to cast the
+      // FunctionPtr to IntptrTy as InjectCoverageForIndirectCalls does.
+      // The value operand should already be a pointer to a func.
+      IRB.CreateCall(SanCovStoreFPointerFunction, {StorePtr, FunctionPtr});
+    }
+}
