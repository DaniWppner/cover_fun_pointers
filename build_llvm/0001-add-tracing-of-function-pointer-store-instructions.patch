@@ -643,6 +653,31 @@ static bool IsInterestingCmp(ICmpInst *CMP, const DominatorTree *DT,
   return true;
 }
 
+/**
+/ Returns true only where the stored value is a pointer to a function.
+/ The stored value can be a statically known function, or it can come
+/ from somewhere like the field of a struct in allocated memory.
+/
+/ Looking at the Type of the stored Value by doing something like
+/  Store->getValueOperand()->stripPointerCasts()->getType()
+/  will fail to identify dynamic functions as a FunctionType because
+/  LLVM's FunctionType refers to statically known global functions,
+/  which the dynamic function by definition cannot be.
+/
+/ This is why we try to use debug information on the stored variable's
+/ supposed type instead.
+/
+/ TO DO: actually attempt the version that "doesn't work"
+**/
+static bool IsInterestingStore(StoreInst *Store) {
+
+  Value *StoreAddr = Store->getPointerOperand();
+
+  if () // To DO: use debug information
+    return true;
+  return false;
+}
